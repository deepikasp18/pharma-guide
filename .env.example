# =============================================================================
# PharmaGuide Health Companion - Environment Configuration
# =============================================================================
# Copy this file to .env and update with your actual values
# Never commit .env file to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Application Environment
# -----------------------------------------------------------------------------
# Options: development, staging, production
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# AWS Configuration
# -----------------------------------------------------------------------------
# AWS credentials for accessing Neptune and other AWS services
# For local development, you can use LocalStack or mock services
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# Optional: AWS Session Token (for temporary credentials)
# AWS_SESSION_TOKEN=your_session_token_here

# -----------------------------------------------------------------------------
# Amazon Neptune Configuration (Knowledge Graph Database)
# -----------------------------------------------------------------------------
# Neptune endpoint URL (without protocol)
# Example: your-cluster.cluster-xxxxx.us-east-1.neptune.amazonaws.com
NEPTUNE_ENDPOINT=your_neptune_endpoint_here
NEPTUNE_PORT=8182

# For local development/testing, you can use:
# - Gremlin Server: localhost:8182
# - Or mock the database in tests
# NEPTUNE_ENDPOINT=localhost

# -----------------------------------------------------------------------------
# OpenSearch Configuration (Full-Text Search)
# -----------------------------------------------------------------------------
# OpenSearch/Elasticsearch endpoint for entity lookup and search
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# Optional: OpenSearch credentials
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=admin

# Optional: Use HTTPS for OpenSearch
# OPENSEARCH_USE_SSL=false

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
# Secret key for JWT token generation (CHANGE IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_change_in_production_min_32_chars

# Encryption key for PII/PHI data (AES-256)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_base64_encoded_encryption_key_here

# JWT Algorithm (default: HS256)
# ALGORITHM=HS256

# Access token expiration in minutes (default: 30)
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
# API server host and port
API_HOST=0.0.0.0
API_PORT=8000

# CORS allowed origins (comma-separated)
# For production, specify exact origins
# CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# Rate limiting
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json, text
# LOG_FORMAT=json

# Log file path (optional, logs to stdout if not set)
# LOG_FILE=/var/log/pharmaguide/app.log

# -----------------------------------------------------------------------------
# NLP & AI Configuration
# -----------------------------------------------------------------------------
# spaCy model to use (will fallback to en_core_web_sm if not available)
# Options: en_core_web_sm, en_core_web_md, en_core_web_lg
# For medical NER, you can use: en_ner_bc5cdr_md (requires scispacy)
SPACY_MODEL=en_core_web_sm

# Optional: BioBERT or other medical NLP model paths
# BIOBERT_MODEL_PATH=/path/to/biobert/model

# -----------------------------------------------------------------------------
# Database & Data Processing
# -----------------------------------------------------------------------------
# Dataset storage paths (for ETL pipeline)
# DATA_DIR=./data
# DATASET_CACHE_DIR=./data/cache

# ETL batch size
# ETL_BATCH_SIZE=1000

# -----------------------------------------------------------------------------
# Testing Configuration
# -----------------------------------------------------------------------------
# Use mock services for testing (set to true for unit tests)
USE_MOCK_SERVICES=false

# Test database endpoint (optional, uses main config if not set)
# TEST_NEPTUNE_ENDPOINT=localhost
# TEST_NEPTUNE_PORT=8182

# Hypothesis property-based testing settings
# HYPOTHESIS_MAX_EXAMPLES=100
# HYPOTHESIS_DEADLINE=None

# -----------------------------------------------------------------------------
# Monitoring & Observability (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
# SENTRY_DSN=https://your_sentry_dsn_here

# Prometheus metrics endpoint
# ENABLE_METRICS=true
# METRICS_PORT=9090

# OpenTelemetry configuration
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=pharmaguide-api

# -----------------------------------------------------------------------------
# External Services (Optional)
# -----------------------------------------------------------------------------
# Email service for notifications
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM_EMAIL=noreply@pharmaguide.com

# SMS service (Twilio, SNS, etc.)
# TWILIO_ACCOUNT_SID=your_account_sid
# TWILIO_AUTH_TOKEN=your_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# Enable/disable specific features
# ENABLE_PHARMACOGENOMICS=true
# ENABLE_TEMPORAL_TRACKING=true
# ENABLE_REAL_TIME_ALERTS=true
# ENABLE_COMPARATIVE_ANALYSIS=true

# -----------------------------------------------------------------------------
# Performance Tuning (Optional)
# -----------------------------------------------------------------------------
# Connection pool sizes
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# Cache configuration
# CACHE_TTL=3600
# CACHE_MAX_SIZE=1000

# Query timeout in seconds
# QUERY_TIMEOUT=30

# -----------------------------------------------------------------------------
# Development Tools (Development Only)
# -----------------------------------------------------------------------------
# Enable auto-reload for development
# RELOAD=true

# Enable debug mode (provides detailed error messages)
# DEBUG=false

# Enable API documentation
# ENABLE_DOCS=true

# =============================================================================
# End of Configuration
# =============================================================================