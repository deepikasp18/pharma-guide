# =============================================================================
# LOCAL DEVELOPMENT CONFIGURATION (No AWS Required)
# =============================================================================
# This configuration allows you to run PharmaGuide locally without AWS services
# Perfect for development, testing, and learning without AWS free tier limits
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Mock Services (NO AWS REQUIRED!)
# -----------------------------------------------------------------------------
# When set to true, all AWS services are mocked in-memory
# No actual AWS credentials or services needed
USE_MOCK_SERVICES=true

# -----------------------------------------------------------------------------
# Security Keys
# -----------------------------------------------------------------------------
# Generate these with: python scripts/generate_keys.py
# Or run: ./scripts/setup_local_dev.sh (automated)

# JWT Secret Key (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=your_generated_secret_key_here

# Encryption Key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_generated_encryption_key_here

# -----------------------------------------------------------------------------
# Mock AWS Configuration
# -----------------------------------------------------------------------------
# These values are not actually used when USE_MOCK_SERVICES=true
# But they're required by the configuration schema
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=mock_key_not_used
AWS_SECRET_ACCESS_KEY=mock_secret_not_used

# -----------------------------------------------------------------------------
# Mock Neptune Configuration
# -----------------------------------------------------------------------------
# Not actually used when USE_MOCK_SERVICES=true
NEPTUNE_ENDPOINT=localhost
NEPTUNE_PORT=8182

# -----------------------------------------------------------------------------
# Mock OpenSearch Configuration
# -----------------------------------------------------------------------------
# Not actually used when USE_MOCK_SERVICES=true
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# NLP Configuration
# -----------------------------------------------------------------------------
# spaCy model to use (install with: python -m spacy download en_core_web_sm)
SPACY_MODEL=en_core_web_sm

# -----------------------------------------------------------------------------
# Testing Configuration
# -----------------------------------------------------------------------------
HYPOTHESIS_MAX_EXAMPLES=100

# =============================================================================
# Quick Start:
# =============================================================================
# 1. Copy this file: cp .env.local.example .env.local
# 2. Generate keys: python scripts/generate_keys.py
# 3. Update SECRET_KEY and ENCRYPTION_KEY above
# 4. Run: ./scripts/run_local.sh
#
# Or use automated setup: ./scripts/setup_local_dev.sh
# =============================================================================
